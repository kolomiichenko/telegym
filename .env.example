# telegym — example environment.
#
# Telegym binaries read configuration straight from the process environment.
# This file documents every variable telegym knows about; all defaults work
# without you setting anything.
#
# To use this file as a real env source:
#   cp .env.example .env
#   set -a; source .env; set +a
#   ./bin/telegym-mock
#
# Or `make init` does the copy step for you.

# ──── telegym-mock ─────────────────────────────────────────────────────
# Bot API HTTP listen address
# TELEGYM_MOCK_LISTEN=:5678

# Prometheus /metrics listen address. Default :9104. Set to empty to disable.
# TELEGYM_MOCK_METRICS_LISTEN=:9104

# Fallback webhook URL when a bot has not called setWebhook
# TELEGYM_MOCK_DEFAULT_WEBHOOK=

# Suppress per-request access logs
# TELEGYM_MOCK_QUIET=false

# ──── echobot (demo bot) ───────────────────────────────────────────────
# Bot token echobot uses to identify itself to the mock
# BOT_TOKEN=1234567890:telegym_default_mock_token_xxxxxxxx

# Mock URL echobot points at (must match TELEGYM_MOCK_LISTEN)
# TELEGYM_MOCK_URL=http://localhost:5678

# Address the mock dispatches updates to (echobot's webhook listener)
# ECHOBOT_LISTEN=:8443

# ──── telegym-proxy (real Telegram → mock relay) ───────────────────────
# Real bot token from @BotFather — REQUIRED when running telegym-proxy
# PROXY_TOKEN=

# Mock URL the proxy forwards real Telegram messages to
# MOCK_URL=http://localhost:5678

# Token of the bot-under-test on the mock side
# MOCK_BOT_TOKEN=1234567890:telegym_default_mock_token_xxxxxxxx

# Address the proxy listens on for mock /forward callbacks
# TELEGYM_PROXY_LISTEN=:8090

# Public URL of the proxy (set when running behind ngrok/cloudflared)
# TELEGYM_PROXY_PUBLIC_URL=

# Restrict the proxy to a single Telegram user_id (optional)
# ALLOWED_USER_ID=

# ──── xk6 scenarios ────────────────────────────────────────────────────
# Token scenarios use when injecting Updates into the mock
# TELEGYM_BOT_TOKEN=1234567890:telegym_default_mock_token_xxxxxxxx
